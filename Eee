-- ESP Function
local espPlayers = {}
local function createESP(player)
    local character = player.Character
    if not character then return end

    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return end

    local box = Drawing.new("Square")
    box.Thickness = 2
    box.Color = espColor
    box.Filled = false
    box.Visible = false

    local healthBar = Drawing.new("Square")
    healthBar.Thickness = 2
    healthBar.Color = Color3.new(0, 1, 0)
    healthBar.Filled = true
    healthBar.Visible = false

    local username = Drawing.new("Text")
    username.Thickness = 2
    username.Color = Color3.new(1, 1, 1)
    username.Size = 18
    username.Center = true
    username.Visible = false

    local tracer = Drawing.new("Line")
    tracer.Thickness = 2
    tracer.Color = espColor
    tracer.Visible = false

    local skeleton = {}
    for _, part in pairs(character:GetChildren()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            local line = Drawing.new("Line")
            line.Thickness = 2
            line.Color = espColor
            line.Visible = false
            table.insert(skeleton, line)
        end
    end

    local function updateESP()
        if not character or not humanoidRootPart or not humanoidRootPart.Parent then
            box:Remove()
            healthBar:Remove()
            username:Remove()
            tracer:Remove()
            for _, line in pairs(skeleton) do
                line:Remove()
            end
            return
        end

        local vector, onScreen = camera:WorldToViewportPoint(humanoidRootPart.Position)
        if onScreen then
            box.Size = Vector2.new(2000 / vector.Z, 2000 / vector.Z)
            box.Position = Vector2.new(vector.X - box.Size.X / 2, vector.Y - box.Size.Y / 2)
            box.Visible = true

            healthBar.Size = Vector2.new(box.Size.X * (character.Humanoid.Health / character.Humanoid.MaxHealth), 5)
            healthBar.Position = Vector2.new(vector.X - box.Size.X / 2, vector.Y - box.Size.Y - 5)
            healthBar.Visible = true

            username.Text = player.Name
            username.Position = Vector2.new(vector.X - username.TextBounds.X / 2, vector.Y - box.Size.Y - 20)
            username.Visible = true

            tracer.From = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
            tracer.To = Vector2.new(vector.X, vector.Y)
            tracer.Visible = true

            for _, line in pairs(skeleton) do
                local part = character:FindFirstChild(line.Name)
                if part then
                    local partVector, partOnScreen = camera:WorldToViewportPoint(part.Position)
                    if partOnScreen then
                        line.From = Vector2.new(vector.X, vector.Y)
                        line.To = Vector2.new(partVector.X, partVector.Y)
                        line.Visible = true
                    else
                        line.Visible = false
                    end
                else
                    line:Remove()
                end
            end
        else
            box.Visible = false
            healthBar.Visible = false
            username.Visible = false
            tracer.Visible = false
            for _, line in pairs(skeleton) do
                line.Visible = false
            end
        end
    end

    espPlayers[player] = {
        box = box,
        healthBar = healthBar,
        username = username,
        tracer = tracer,
        skeleton = skeleton,
        updateESP = updateESP
    }

    RunService.RenderStepped:Connect(function()
        if espEnabled then
            updateESP()
        end
    end)
end

-- Update ESP every 5 seconds
local function updateESPPlayers()
    if espEnabled then
        for player, espData in pairs(espPlayers) do
            espData.updateESP()
        end
    end
end

RunService.Heartbeat:Connect(function()
    updateESPPlayers()
end)

-- Aimbot Function
local function aimAtPlayer(player)
    local character = player.Character
    if not character then return end

    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return end

    local head = character:FindFirstChild("Head")
    if not head then return end

    local targetPosition = head.Position
    local localPosition = localPlayer.Character.HumanoidRootPart.Position
    local direction = (targetPosition - localPosition).unit
    direction = Vector3.new(direction.X, 0, direction.Z) -- Only move horizontally

    localPlayer.Character:SetPrimaryPartCFrame(CFrame.new(localPosition, localPosition + direction))
end

-- Auto Shoot Function
local function autoShoot(player)
    local character = player.Character
    if not character then return end

    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return end

    local head = character:FindFirstChild("Head")
    if not head then return end

    local ray = Ray.new(localPlayer.Character.HumanoidRootPart.Position, (head.Position - localPlayer.Character.HumanoidRootPart.Position).unit * 1000)
    local hit, position = Workspace:FindPartOnRay(ray, localPlayer.Character)

    if hit and hit.Parent == character then
        local mouse = localPlayer:GetMouse()
        mouse.Button1Down:Connect(function()
            if autoShootEnabled then
                mouse.Button1Down:Connect(function()
                    localPlayer.Character.Humanoid:MoveTo(head.Position)
                end)
            end
        end)
    end
end

