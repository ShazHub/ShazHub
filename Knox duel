local LEFT_PATH = {Vector3.new(-473, -7, 113), Vector3.new(-475, -7, 90), Vector3.new(-475, -7, 25), Vector3.new(-487, -5, 25)}
local RIGHT_PATH = {Vector3.new(-472, -7, 26), Vector3.new(-473, -7, 92), Vector3.new(-477, -7, 93), Vector3.new(-486, -5, 98)}

local function isRagdolled()
    local h = lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
    if not h then return false end
    local s = h:GetState()
    return s == Enum.HumanoidStateType.Ragdoll or s == Enum.HumanoidStateType.FallingDown or s == Enum.HumanoidStateType.Physics or h.PlatformStand
end

local function getNearestNodeIndex(path)
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return 1 end
    local idx, minD = 1, math.huge
    for i, pos in ipairs(path) do
        local d = (pos - hrp.Position).Magnitude
        if d < minD then minD = d; idx = i end
    end
    return idx
end

