local HOLD_DURATION = 0.2
local isGrabbing = false

local function patchPrompt(obj)
    if obj:IsA("ProximityPrompt") and obj.ActionText:find("Steal") then
        obj.MaxActivationDistance = 999999
        obj.RequiresLineOfSight = false
        obj.Style = Enum.ProximityPromptStyle.Custom
    end
end
for _, v in workspace:GetDescendants() do patchPrompt(v) end
workspace.DescendantAdded:Connect(patchPrompt)

local function getAbsoluteNearest()
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local best, dist = nil, math.huge
    for _, v in workspace:GetDescendants() do
        if v:IsA("ProximityPrompt") and v.ActionText:find("Steal") and v.Enabled then
            local pos = (v.Parent:IsA("BasePart") and v.Parent.Position) or (v.Parent:IsA("Attachment") and v.Parent.WorldPosition)
            if pos then
                local d = (pos - hrp.Position).Magnitude
                if d < dist then dist = d; best = v end
            end
        end
    end
    return best
end

local function preciseMove(target, speed)
    local char = lp.Character
    if not char then return end
    local fixedY = target.Y + getgenv().KnoxConfig.HeightOffset
    local targetPos = Vector3.new(target.X, fixedY, target.Z)

    while getgenv().KnoxConfig.AutoPlay do
        svcs.rs.Heartbeat:Wait()
        if isRagdolled() then break end

        local cur = char:GetPivot().Position
        local dist2D = (Vector2.new(cur.X, cur.Z) - Vector2.new(targetPos.X, targetPos.Z)).Magnitude
        if dist2D < 1.1 then break end

        local dir = (Vector3.new(targetPos.X, 0, targetPos.Z) - Vector3.new(cur.X, 0, cur.Z)).Unit
        local nextPos = cur + (dir * (speed / 60))

        char:PivotTo(CFrame.new(Vector3.new(nextPos.X, fixedY, nextPos.Z), targetPos))
    end
end

local function instantSteal()
    if isGrabbing then return end
    isGrabbing = true
    BarContainer.Visible = true

    local target = getAbsoluteNearest()
    
    if target then
        pcall(function() target:InputHoldBegin() end)
        
        local start = tick()
        while isGrabbing and (tick() - start) < HOLD_DURATION do
            local progress = (tick() - start) / HOLD_DURATION
            ProgressBar.Size = UDim2.new(math.clamp(progress, 0, 1), 0, 1, 0)
            svcs.rs.Heartbeat:Wait()
        end
        
        pcall(function() target:InputHoldEnd() end)
        
        if fireproximityprompt then
            fireproximityprompt(target)
        end
    end
    
    task.wait(0.1)
    BarContainer.Visible = false
    ProgressBar.Size = UDim2.new(0, 0, 1, 0)
    isGrabbing = false
end

local function startLoop()
    while getgenv().KnoxConfig.AutoPlay do
        local char = lp.Character or lp.CharacterAdded:Wait()
        local root = char:WaitForChild("HumanoidRootPart")
        applyGod(char)

        if char:FindFirstChildOfClass("Humanoid") then
            char.Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
        end

        local useRight = (root.Position - RIGHT_PATH[1]).Magnitude < (root.Position - LEFT_PATH[1]).Magnitude
        local path = useRight and RIGHT_PATH or LEFT_PATH

        for i = getNearestNodeIndex(path), #path do
            if not getgenv().KnoxConfig.AutoPlay then break end
            statusLabel.Text = "P:"..i
            preciseMove(path[i], getgenv().KnoxConfig.GoingSpeed)
        end

        if getgenv().KnoxConfig.AutoPlay then
            statusLabel.Text = "STEAL!"
            instantSteal()
        end

        for i = getNearestNodeIndex(path) - 1, 1, -1 do
            if not getgenv().KnoxConfig.AutoPlay then break end
            statusLabel.Text = "R:"..i
            preciseMove(path[i], getgenv().KnoxConfig.ReturnSpeed)
            
            
            local pushRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if pushRoot then
                for push = 1, 4 do
                    pushRoot.CFrame = pushRoot.CFrame + (pushRoot.CFrame.LookVector * 7.5)
                    task.wait(0.008)
                end
            end
        end

        task.wait(0.05)
    end
end

